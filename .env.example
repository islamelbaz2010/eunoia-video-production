# Eunoia Media OS — Environment Variable Reference
# Copy this file to .env and fill in all values before running the application.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Full PostgreSQL connection string.
# Local default after `supabase start`: postgresql://postgres:postgres@localhost:54322/postgres
DATABASE_URL=

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------

# Project URL (local default: http://localhost:54321)
SUPABASE_URL=

# Public anon key — safe for client-side use.
# Printed by `supabase start` as "anon key".
SUPABASE_ANON_KEY=

# Secret service-role key — server-side only, never expose publicly.
# Printed by `supabase start` as "service_role key".
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------

# Base URL of the n8n instance (e.g., http://localhost:5678 or https://n8n.example.com)
N8N_BASE_URL=

# n8n API key for programmatic workflow access.
# Generate at: n8n instance → Settings → API → Create API key
N8N_API_KEY=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Supabase Storage bucket for raw project assets (footage, audio, graphics).
STORAGE_BUCKET_ASSETS=assets

# Supabase Storage bucket for final client deliverables and exports.
STORAGE_BUCKET_DELIVERABLES=deliverables

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Logging verbosity: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# OpenAI API key — used by Supabase Studio AI assistant (optional).
OPENAI_API_KEY=
