{
  "name": "eunoia-media-os",
  "version": "0.2.0",
  "description": "Eunoia Media OS — video production management system",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:clean": "rm -rf dist && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.test.json",
